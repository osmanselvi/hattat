{% extends 'base.html.twig' %}

{% block title %}Ödev Detayı - {{ assignment.title }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h3 class="m-0">{{ assignment.title }}</h3>
                    {% if assignment.status == 'beklemede' %}
                        <span class="badge bg-warning text-dark fs-6">Beklemede</span>
                    {% elseif assignment.status == 'teslim edildi' %}
                        <span class="badge bg-info fs-6">Teslim Edildi</span>
                    {% else %}
                        <span class="badge bg-success fs-6">Düzeltildi</span>
                    {% endif %}
                </div>
                <div class="card-body">
                    <p class="text-muted">Son Teslim Tarihi: {{ assignment.dueDate|date('d.m.Y') }}</p>
                    
                    <h5 class="mt-4">Açıklama</h5>
                    <div class="p-3 bg-light rounded">
                        {{ assignment.description|nl2br }}
                    </div>

                    <div class="mt-5 text-center">
                        {% if assignment.status == 'beklemede' %}
                            <a href="{{ path('app_student_assignment_submit', {'id': assignment.id}) }}" class="btn btn-primary btn-lg">Ödevi Teslim Et</a>
                        {% else %}
                            <a href="{{ path('app_student_corrections') }}" class="btn btn-outline-primary">Düzeltmelerimi Gör</a>
                        {% endif %}
                        <a href="{{ path('app_student_assignments') }}" class="btn btn-outline-secondary ms-2">Ödevlerime Dön</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

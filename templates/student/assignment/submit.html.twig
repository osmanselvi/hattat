{% extends 'base.html.twig' %}

{% block title %}Ödev Teslimi - {{ assignment.title }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Ödev Teslimi: {{ assignment.title }}</h5>
                </div>
                <div class="card-body p-4">
                    <form method="post" enctype="multipart/form-data">
                        <div class="mb-4">
                            <label for="artworkImage" class="form-label fw-bold">Eser Görseli Yükle (Zorunlu)</label>
                            <input type="file" class="form-control form-control-lg" id="artworkImage" name="artworkImage" accept="image/jpeg, image/png" required>
                            <div class="form-text">Maksimum 10MB boyutunda, .jpg veya .png formatında olmalıdır. Yüksek çözünürlüklü ve net ışıkta çekilmiş bir fotoğraf yüklemeye özen gösterin.</div>
                            
                            <!-- Preview Image container -->
                            <div class="mt-3 text-center d-none" id="imagePreviewContainer">
                                <img id="imagePreview" src="#" alt="Görsel Önizleme" class="img-fluid img-thumbnail" style="max-height: 300px;">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="studentNote" class="form-label fw-bold">Öğretmene İletmek İstediğiniz Not (İsteğe Bağlı)</label>
                            <textarea class="form-control" id="studentNote" name="studentNote" rows="4" placeholder="Eseri yazarken zorlandığınız kısımlar, sormak istedikleriniz..."></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="{{ path('app_student_assignment_detail', {'id': assignment.id}) }}" class="btn btn-outline-secondary">İptal</a>
                            <button type="submit" class="btn btn-success px-5">Teslim Et</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('artworkImage').addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            // Check size (max 10MB)
            if (file.size > 10 * 1024 * 1024) {
                alert('Dosya boyutu çok yüksek. Maksimum 10MB yükleyebilirsiniz.');
                e.target.value = ''; // clear
                document.getElementById('imagePreviewContainer').classList.add('d-none');
                return;
            }

            const reader = new FileReader();
            reader.onload = function(event) {
                document.getElementById('imagePreview').src = event.target.result;
                document.getElementById('imagePreviewContainer').classList.remove('d-none');
            };
            reader.readAsDataURL(file);
        }
    });
</script>
{% endblock %}

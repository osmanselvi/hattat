{% extends 'base.html.twig' %}

{% block title %}Öğrenci Paneli{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="text-gold">Hoş Geldiniz, {{ app.user.name }}</h2>
            {% if unreadMessages > 0 %}
                <a href="{{ path('app_student_messages') }}" class="btn btn-warning">
                    <i class="bi bi-envelope-fill"></i> {{ unreadMessages }} Yeni Mesaj
                </a>
            {% endif %}
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-md-4">
            <div class="card text-center shadow-sm">
                <div class="card-body py-4">
                    <h1 class="display-4 text-primary">{{ pendingCount }}</h1>
                    <p class="text-muted mb-0">Bekleyen Ödev</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm">
                <div class="card-body py-4">
                    <h1 class="display-4 text-info">{{ submittedCount }}</h1>
                    <p class="text-muted mb-0">Teslim Edilen</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm">
                <div class="card-body py-4">
                    <h1 class="display-4 text-success">{{ correctedCount }}</h1>
                    <p class="text-muted mb-0">Düzeltilmiş</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-3">
            <div class="list-group shadow-sm">
                <a href="{{ path('app_student_dashboard') }}" class="list-group-item list-group-item-action active">Panelim</a>
                <a href="{{ path('app_student_assignments') }}" class="list-group-item list-group-item-action">Ödevlerim</a>
                <a href="{{ path('app_student_corrections') }}" class="list-group-item list-group-item-action">Düzeltmelerimi Gör</a>
                <a href="{{ path('app_student_messages') }}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                    Mesajlar
                    {% if unreadMessages > 0 %}
                        <span class="badge bg-danger rounded-pill">{{ unreadMessages }}</span>
                    {% endif %}
                </a>
                <a href="{{ path('app_student_profile') }}" class="list-group-item list-group-item-action">Profilim</a>
            </div>
        </div>
        <div class="col-md-9">
            <h4 class="mb-3">Son Ödevler</h4>
            <div class="list-group shadow-sm">
                {% for assignment in assignments %}
                    <a href="{{ path('app_student_assignment_detail', {'id': assignment.id}) }}" class="list-group-item list-group-item-action flex-column align-items-start">
                        <div class="d-flex w-100 justify-content-between">
                            <h5 class="mb-1">{{ assignment.title }}</h5>
                            <small class="text-muted">Son Tarih: {{ assignment.dueDate|date('d.m.Y') }}</small>
                        </div>
                        <p class="mb-1 text-truncate">{{ assignment.description }}</p>
                        <small>
                            Durum: 
                            {% if assignment.status == 'beklemede' %}
                                <span class="badge bg-warning text-dark">Beklemede</span>
                            {% elseif assignment.status == 'teslim edildi' %}
                                <span class="badge bg-info">Teslim Edildi</span>
                            {% else %}
                                <span class="badge bg-success">Düzeltildi</span>
                            {% endif %}
                        </small>
                    </a>
                {% else %}
                    <div class="list-group-item">Henüz atanmış bir ödev bulunmuyor.</div>
                {% endfor %}
            </div>
            
            {% if assignments|length > 0 %}
                <div class="mt-3 text-end">
                    <a href="{{ path('app_student_assignments') }}" class="btn btn-outline-primary btn-sm">Tüm Ödevleri Gör</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

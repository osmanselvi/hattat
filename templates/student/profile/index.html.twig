{% extends 'base.html.twig' %}

{% block title %}Profilim{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="list-group shadow-sm">
                <a href="{{ path('app_student_dashboard') }}" class="list-group-item list-group-item-action">Panelim</a>
                <a href="{{ path('app_student_assignments') }}" class="list-group-item list-group-item-action">Ödevlerim</a>
                <a href="{{ path('app_student_corrections') }}" class="list-group-item list-group-item-action">Düzeltmelerimi Gör</a>
                <a href="{{ path('app_student_messages') }}" class="list-group-item list-group-item-action">Mesajlar</a>
                <a href="{{ path('app_student_profile') }}" class="list-group-item list-group-item-action active">Profilim</a>
            </div>
        </div>
        
        <div class="col-md-9">
            <h3 class="text-gold mb-4">Profil Bilgilerim</h3>
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form method="post" enctype="multipart/form-data">
                        <div class="row">
                            <div class="col-md-4 text-center mb-4">
                                {% if user.avatar %}
                                    <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" class="rounded-circle img-thumbnail mb-3" style="width: 150px; height: 150px; object-fit: cover;" alt="Avatar">
                                {% else %}
                                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white mx-auto mb-3" style="width: 150px; height: 150px; font-size: 3rem;">
                                        {{ user.name|first|upper }}
                                    </div>
                                {% endif %}
                                <div class="mb-3 text-start">
                                    <label for="avatar" class="form-label small">Profil Fotoğrafı (Opsiyonel)</label>
                                    <input type="file" class="form-control form-control-sm" id="avatar" name="avatar" accept="image/jpeg, image/png">
                                </div>
                            </div>
                            
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label for="name" class="form-label">Ad Soyad</label>
                                    <input type="text" class="form-control" id="name" name="name" value="{{ user.name }}" required>
                                </div>
                                <div class="mb-3">
                                    <label for="email" class="form-label">E-posta (Değiştirilemez)</label>
                                    <input type="email" class="form-control bg-light" id="email" value="{{ user.email }}" readonly>
                                </div>
                                <div class="mb-3">
                                    <label for="phone" class="form-label">Telefon</label>
                                    <input type="text" class="form-control" id="phone" name="phone" value="{{ student.phone }}">
                                </div>
                                <hr>
                                <h5 class="mb-3 text-muted">Şifre Değiştir</h5>
                                <div class="mb-3">
                                    <label for="password" class="form-label">Yeni Şifre</label>
                                    <input type="password" class="form-control" id="password" name="password" placeholder="Boş bırakırsanız değişmez">
                                </div>
                                
                                <div class="text-end mt-4">
                                    <button type="submit" class="btn btn-primary px-4">Değişiklikleri Kaydet</button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

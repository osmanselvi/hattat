{% extends 'base.html.twig' %}

{% block title %}İletişim{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="text-ink display-4">İletişim</h1>
        <div class="mx-auto" style="width: 60px; height: 3px; background-color: var(--color-gold);"></div>
        <p class="lead text-muted mt-4">Eser siparişleri, sergi davetleri veya eğitim talepleri için benimle iletişime geçebilirsiniz.</p>
    </div>

    <div class="row g-5">
        <!-- Contact Form -->
        <div class="col-md-7">
            <div class="card shadow-sm border-0 bg-white">
                <div class="card-body p-4 p-md-5">
                    <h3 class="mb-4 text-ink">Bize Ulaşın</h3>
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="mb-3">
                            {{ form_row(form.name) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.email) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.subject) }}
                        </div>
                        <div class="mb-4">
                            {{ form_row(form.message) }}
                        </div>
                        {{ form_row(form.submit) }}
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <!-- Contact Info & Map -->
        <div class="col-md-5">
            <div class="mb-5">
                <h4 class="text-ink mb-4">İletişim Bilgileri</h4>
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-parchment rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-geo-alt fs-4 text-gold"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">Adres</h6>
                        <span class="text-muted">{{ site_settings().contactAddress|default('İstanbul, Türkiye') }}</span>
                    </div>
                </div>
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-parchment rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-envelope fs-4 text-gold"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">E-posta</h6>
                        <span class="text-muted">{{ site_settings().contactEmail|default('info@hattatportfolyo.com') }}</span>
                    </div>
                </div>
                <div class="d-flex align-items-center">
                    <div class="bg-parchment rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px;">
                        <i class="bi bi-telephone fs-4 text-gold"></i>
                    </div>
                    <div>
                        <h6 class="mb-0">Telefon</h6>
                        <span class="text-muted">{{ site_settings().contactPhone|default('+90 (555) 123 45 67') }}</span>
                    </div>
                </div>
            </div>

            <!-- Google Maps Embed -->
            <div class="card shadow-sm border-0 overflow-hidden">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d192697.7932743176!2d28.872096338541295!3d41.00549581024303!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14caa7040068086b%3A0xe1ccfe98bc01b0d0!2zxLBzdGFuYnVs!5e0!3m2!1str!2str!4v1700000000000!5m2!1str!2str" width="100%" height="250" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </div>
</div>
{% endblock %}

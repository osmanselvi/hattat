{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Profilim{% endblock %}

{% block main %}
<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-4 text-center mb-4">
                        {% if user.avatar %}
                            <img src="{{ asset('uploads/avatars/' ~ user.avatar) }}" class="rounded-circle img-thumbnail mb-3 shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="Avatar">
                        {% else %}
                            <div class="rounded-circle bg-primary d-flex align-items-center justify-content-center text-white mx-auto mb-3 shadow-sm" style="width: 150px; height: 150px; font-size: 3rem;">
                                {{ user.name|first|upper }}
                            </div>
                        {% endif %}
                        <div class="mb-3 text-start">
                            <label for="avatar" class="form-label small text-muted">Profil Fotoğrafı (Opsiyonel)</label>
                            <input type="file" class="form-control form-control-sm" id="avatar" name="avatar" accept="image/jpeg, image/png">
                        </div>
                    </div>
                    
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label for="name" class="form-label">Ad Soyad</label>
                            <input type="text" class="form-control" id="name" name="name" value="{{ user.name }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="email" class="form-label">E-posta (Giriş için, değiştirilemez)</label>
                            <input type="email" class="form-control bg-light" id="email" value="{{ user.email }}" readonly>
                        </div>
                        <hr>
                        <h5 class="mb-3 text-muted">Şifre Değiştir</h5>
                        <div class="mb-3">
                            <label for="password" class="form-label">Yeni Şifre</label>
                            <input type="password" class="form-control" id="password" name="password" placeholder="Mevcut şifreyi korumak için boş bırakın">
                        </div>
                        
                        <div class="text-end mt-4">
                            <button type="submit" class="btn btn-primary px-4">Değişiklikleri Kaydet</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

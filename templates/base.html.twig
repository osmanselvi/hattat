<!DOCTYPE html>
<html lang="tr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Hattat Web Sitesi{% endblock %}</title>
        
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Amiri:ital,wght@0,400;0,700;1,400;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
        
        <!-- Bootstrap 5 CSS & Icons -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
        
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>✒️</text></svg>">
        
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg bg-parchment sticky-top shadow-sm">
            <div class="container">
                <a class="navbar-brand fs-3 text-ink" href="{{ path('app_home')|default('/') }}">
                    <strong>Hattat</strong> Portfolyo
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Menüyü Aç">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_home')|default('/') }}">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_gallery')|default('/galeri') }}">Galeri</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_exhibitions')|default('/sergiler') }}">Sergiler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_news')|default('/haberler') }}">Haberler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_about')|default('/hakkinda') }}">Hakkında</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_contact')|default('/iletisim') }}">İletişim</a>
                        </li>
                    </ul>
                    <div class="d-flex">
                        {% if is_granted('ROLE_ADMIN') %}
                            <a href="{{ path('admin') }}" class="btn btn-outline-dark me-2">Admin Paneli</a>
                            <a href="{{ path('app_logout') }}" class="btn btn-dark">Çıkış Yap</a>
                        {% elseif is_granted('ROLE_STUDENT') %}
                            <a href="{{ path('app_student_dashboard') }}" class="btn btn-outline-dark me-2">Öğrenci Paneli</a>
                            <a href="{{ path('app_logout') }}" class="btn btn-dark">Çıkış Yap</a>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-outline-dark"><i class="bi bi-box-arrow-in-right"></i> Giriş Yap</a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </nav>

        <!-- Flash Messages -->
        <div class="container mt-3">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Kapat"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        <!-- Main Content -->
        <main>
            {% block body %}{% endblock %}
        </main>

        <!-- Footer -->
        <footer class="py-5 mt-5">
            <div class="container">
                <div class="row">
                    <div class="col-md-4 mb-4 mb-md-0">
                        <h4 class="text-gold mb-3">Hattat Portfolyo</h4>
                        <p class="text-white-50">Geleneksel İslam Sanatları ve modern web tasarımının buluşma noktası. Özel eserler, eğitimler ve daha fazlası.</p>
                    </div>
                    <div class="col-md-4 mb-4 mb-md-0">
                        <h5 class="text-gold mb-3">Hızlı Bağlantılar</h5>
                        <ul class="list-unstyled">
                            <li><a href="{{ path('app_gallery')|default('/galeri') }}" class="text-decoration-none">Eser Galerisi</a></li>
                            <li><a href="{{ path('app_exhibitions')|default('/sergiler') }}" class="text-decoration-none">Yaklaşan Sergiler</a></li>
                            <li><a href="{{ path('app_about')|default('/hakkinda') }}" class="text-decoration-none">Biyografi & Ödüller</a></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <h5 class="text-gold mb-3">İletişim</h5>
                        <ul class="list-unstyled text-white-50">
                            <li>E-posta: {{ site_settings().contactEmail|default('info@hattatportfolyo.com') }}</li>
                            <li>Adres: {{ site_settings().contactAddress|default('İstanbul, Türkiye') }}</li>
                        </ul>
                        <div class="mt-3">
                            <a href="{{ site_settings().socialInstagram|default('#') }}" target="_blank" class="me-3 fs-4"><i class="bi bi-instagram"></i></a>
                            <a href="{{ site_settings().socialTwitter|default('#') }}" target="_blank" class="fs-4"><i class="bi bi-twitter"></i></a>
                        </div>
                    </div>
                </div>
                <div class="row mt-4 pt-4 border-top border-secondary text-center">
                    <div class="col-12 text-white-50">
                        &copy; {{ 'now'|date('Y') }} Hattat Portfolyo. Tüm hakları saklıdır.
                    </div>
                </div>
            </div>
        </footer>

        <!-- Bootstrap 5 JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>

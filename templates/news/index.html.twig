{% extends 'base.html.twig' %}

{% block title %}Haberler ve Güncellemeler{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="text-ink display-4">Haberler</h1>
        <div class="mx-auto" style="width: 60px; height: 3px; background-color: var(--color-gold);"></div>
    </div>

    <div class="row g-4">
        {% for news in newsList %}
            <div class="col-md-4">
                <div class="card shadow-sm h-100 border-0">
                    {% if news.coverImage %}
                        <a href="{{ path('app_news_detail', {'slug': news.slug}) }}">
                            <img src="{{ asset('uploads/news/' ~ news.coverImage) }}" class="card-img-top" alt="{{ news.title }}" style="height: 220px; object-fit: cover;">
                        </a>
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <small class="text-gold fw-bold mb-2">{{ news.publishedAt|date('d F Y') }}</small>
                        <h4 class="card-title text-ink">
                            <a href="{{ path('app_news_detail', {'slug': news.slug}) }}" class="text-decoration-none text-ink">{{ news.title }}</a>
                        </h4>
                        <p class="card-text text-muted mb-4">{{ news.content|striptags|slice(0, 120) }}...</p>
                        <div class="mt-auto">
                            <a href="{{ path('app_news_detail', {'slug': news.slug}) }}" class="btn btn-outline-primary rounded-pill px-4">Okumaya Devam Et</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <p class="text-muted fs-5">Henüz yayınlanmış bir haber bulunmuyor.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}

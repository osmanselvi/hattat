{% extends 'base.html.twig' %}

{% block title %}Sergiler{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="text-ink display-4">Sergiler</h1>
        <div class="mx-auto" style="width: 60px; height: 3px; background-color: var(--color-gold);"></div>
    </div>

    <!-- Tabs -->
    <ul class="nav nav-pills justify-content-center mb-5" id="exhibitionTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active rounded-pill px-4 me-2" id="active-tab" data-bs-toggle="pill" data-bs-target="#active" type="button" role="tab">Aktif & Yaklaşan Sergiler</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link rounded-pill px-4" id="past-tab" data-bs-toggle="pill" data-bs-target="#past" type="button" role="tab">Geçmiş Sergiler</button>
        </li>
    </ul>

    <div class="tab-content" id="exhibitionTabsContent">
        <!-- Active Exhibitions -->
        <div class="tab-pane fade show active" id="active" role="tabpanel">
            <div class="row g-4">
                {% for exhibition in activeExhibitions %}
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm h-100 border-0">
                            {% if exhibition.coverImage %}
                                <img src="{{ asset('uploads/exhibitions/' ~ exhibition.coverImage) }}" class="card-img-top" alt="{{ exhibition.title }}" style="height: 250px; object-fit: cover;">
                            {% else %}
                                <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 250px;">Görsel Yok</div>
                            {% endif %}
                            <div class="card-body">
                                <h5 class="card-title text-ink">{{ exhibition.title }}</h5>
                                <h6 class="card-subtitle mb-3 text-gold"><i class="bi bi-calendar3"></i> {{ exhibition.startDate|date('d.m.Y') }} - {{ exhibition.endDate|date('d.m.Y') }}</h6>
                                <p class="text-muted"><i class="bi bi-geo-alt"></i> {{ exhibition.location }}</p>
                                <a href="{{ path('app_exhibition_detail', {'id': exhibition.id}) }}" class="btn btn-primary mt-2">Sergi Detayları</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center py-4">
                        <p class="text-muted">Şu anda aktif veya yaklaşan bir sergi bulunmamaktadır.</p>
                    </div>
                {% endfor %}
            </div>
        </div>

        <!-- Past Exhibitions -->
        <div class="tab-pane fade" id="past" role="tabpanel">
            <div class="row g-4">
                {% for exhibition in pastExhibitions %}
                    <div class="col-md-6 col-lg-4">
                        <div class="card shadow-sm h-100 border-0 opacity-75">
                            {% if exhibition.coverImage %}
                                <img src="{{ asset('uploads/exhibitions/' ~ exhibition.coverImage) }}" class="card-img-top" alt="{{ exhibition.title }}" style="height: 200px; object-fit: cover;">
                            {% endif %}
                            <div class="card-body">
                                <h5 class="card-title">{{ exhibition.title }}</h5>
                                <h6 class="card-subtitle mb-3 text-muted">{{ exhibition.startDate|date('d.m.Y') }} - {{ exhibition.endDate|date('d.m.Y') }}</h6>
                                <p class="small text-muted">{{ exhibition.location }}</p>
                                <a href="{{ path('app_exhibition_detail', {'id': exhibition.id}) }}" class="btn btn-sm btn-outline-secondary mt-2">Detayları Gör</a>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12 text-center py-4">
                        <p class="text-muted">Geçmiş sergi kaydı bulunmamaktadır.</p>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

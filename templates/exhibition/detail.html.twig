{% extends 'base.html.twig' %}

{% block title %}{{ exhibition.title }} - Sergi Detayı{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_exhibitions') }}" class="text-decoration-none text-gold">Sergiler</a></li>
            <li class="breadcrumb-item active" aria-current="page">{{ exhibition.title }}</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-lg-8">
            <h1 class="text-ink mb-3">{{ exhibition.title }}</h1>
            
            <div class="d-flex align-items-center mb-4 text-muted">
                <div class="me-4"><i class="bi bi-calendar3 text-gold"></i> {{ exhibition.startDate|date('d.m.Y') }} - {{ exhibition.endDate|date('d.m.Y') }}</div>
                <div><i class="bi bi-geo-alt text-gold"></i> {{ exhibition.location }}</div>
            </div>
            
            {% if exhibition.coverImage %}
                <img src="{{ asset('uploads/exhibitions/' ~ exhibition.coverImage) }}" class="img-fluid rounded shadow-sm mb-5 w-100" alt="{{ exhibition.title }}">
            {% endif %}

            <div class="content fs-5 text-dark" style="line-height: 1.8;">
                {{ exhibition.description|nl2br }}
            </div>
        </div>
        
        <div class="col-lg-4 mt-5 mt-lg-0">
            <div class="card shadow-sm border-0 bg-parchment">
                <div class="card-body p-4">
                    <h4 class="text-ink mb-4">Sergi Bilgileri</h4>
                    
                    <div class="mb-3">
                        <h6 class="text-muted mb-1">Durum</h6>
                        {% if exhibition.isActive %}
                            <span class="badge bg-success fs-6">Aktif / Yaklaşan</span>
                        {% else %}
                            <span class="badge bg-secondary fs-6">Sona Erdi</span>
                        {% endif %}
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted mb-1">Başlangıç</h6>
                        <p class="fw-bold">{{ exhibition.startDate|date('d F Y') }}</p>
                    </div>
                    
                    <div class="mb-3">
                        <h6 class="text-muted mb-1">Bitiş</h6>
                        <p class="fw-bold">{{ exhibition.endDate|date('d F Y') }}</p>
                    </div>
                    
                    <div class="mb-4">
                        <h6 class="text-muted mb-1">Mekan</h6>
                        <p class="fw-bold">{{ exhibition.location }}</p>
                    </div>
                    
                    <div class="d-grid">
                        <a href="{{ path('app_contact') }}" class="btn btn-outline-dark">Ziyaret İçin İletişim</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
